      <data key="d0">Ministry Of Health And Quality Of Life / Mauritius Institute Of Health / World Health Organisation</data>
      <data key="d1">organization</data>
      <data key="d2">Organizations responsible for the content published in the medical guidelines.</data>
      <data key="d3">chunk-0a8a07023292447dd472b098aca92a15</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190148</data>
      <data key="d6" />
    </node>
    <node id="Non-Communicable Disease">
      <data key="d0">Non-Communicable Disease</data>
      <data key="d1">concept</data>
      <data key="d2">NCD is the focus area of the guidelines, requiring primary and secondary prevention.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190148</data>
      <data key="d6" />
    </node>
    <node id="Physical Activity">
      <data key="d0">Physical Activity</data>
      <data key="d1">method</data>
      <data key="d2">Physical Activity intervention is recommended for CVD patients, aiming for minimum 30-60 minutes of moderate intensity exercise per week.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190148</data>
      <data key="d6" />
    </node>
    <node id="Weight Management">
      <data key="d0">Weight Management</data>
      <data key="d1">method</data>
      <data key="d2">Weight Management is required for CVD patients, emphasizing the need for weight loss due to associated increased TG and glucose levels.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190148</data>
      <data key="d6" />
    </node>
    <node id="Blood Pressure Control">
      <data key="d0">Blood Pressure Control</data>
      <data key="d1">method</data>
      <data key="d2">Blood Pressure Control involves lifestyle modification and individualized antihypertensive drug use to maintain a blood pressure below 140/90 mmHg.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190148</data>
      <data key="d6" />
    </node>
    <node id="Lipid Management">
      <data key="d0">Lipid Management</data>
      <data key="d1">method</data>
      <data key="d2">Lipid Management guidelines recommend specific dietary restrictions and drug therapies to achieve target cholesterol levels (e.g., LDL &lt; 100 mg/dl).</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190149</data>
      <data key="d6" />
    </node>
    <node id="Oestrogen Replacement Therapy">
      <data key="d0">Oestrogen Replacement Therapy</data>
      <data key="d1">method</data>
      <data key="d2">Oestrogen Replacement Therapy is specifically considered for post-menopausal women who have multiple risk factors for CHD.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190149</data>
      <data key="d6" />
    </node>
    <node id="Antiplatelets/Anticoagulants">
      <data key="d0">Antiplatelets/Anticoagulants</data>
      <data key="d1">content</data>
      <data key="d2">These agents include starting ASA 75 to 300 mg or managing warfarin to maintain an international normalized ratio of 2 to 3.5.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190149</data>
      <data key="d6" />
    </node>
    <node id="Primary Prevention">
      <data key="d0">Primary Prevention</data>
      <data key="d1">concept</data>
      <data key="d2">Primary Prevention strategies are outlined in the guidelines for reducing NCD and CVD risk factors.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190149</data>
      <data key="d6" />
    </node>
    <node id="Secondary Prevention">
      <data key="d0">Secondary Prevention</data>
      <data key="d1">concept</data>
      <data key="d2">Secondary Prevention strategies are outlined in the guidelines for managing existing NCD and CVD risks.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9&lt;SEP&gt;chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190149</data>
      <data key="d6" />
    </node>
    <node id="Triglyceride Level">
      <data key="d0">Triglyceride Level</data>
      <data key="d1">data</data>
      <data key="d2">Triglyceride levels are measured for lipid management, with thresholds ranging from &lt; 200 mg/dl to &gt; 400 mg/dl.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190150</data>
      <data key="d6" />
    </node>
    <node id="LDL Cholesterol">
      <data key="d0">LDL Cholesterol</data>
      <data key="d1">data</data>
      <data key="d2">Low-density lipoprotein (LDL) cholesterol has specific target ranges, including &lt; 100 mg/dl and 100-130 mg/dl, crucial for lipid management.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190210</data>
      <data key="d6" />
    </node>
    <node id="Blood Pressure Readings">
      <data key="d0">Blood Pressure Readings</data>
      <data key="d1">data</data>
      <data key="d2">Specific blood pressure targets are set for hypertension control, generally recommending a goal equal or less than 140/90 mmHg.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190210</data>
      <data key="d6" />
    </node>
    <node id="Statin Drug Therapy">
      <data key="d0">Statin Drug Therapy</data>
      <data key="d1">content</data>
      <data key="d2">Statin treatment is a suggested drug therapy for lipid management when LDL goals are not achieved.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190210</data>
      <data key="d6" />
    </node>
    <node id="Fibrate Drug Therapy">
      <data key="d0">Fibrate Drug Therapy</data>
      <data key="d1">content</data>
      <data key="d2">Fibrate therapy is listed as a suggested drug therapy option for managing high triglycerides.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190210</data>
      <data key="d6" />
    </node>
    <node id="Niacin Drug Therapy">
      <data key="d0">Niacin Drug Therapy</data>
      <data key="d1">content</data>
      <data key="d2">Niacin therapy is a suggested drug therapy option for lipid management, sometimes combined with statin treatment.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190211</data>
      <data key="d6" />
    </node>
    <node id="International Normalized Ratio">
      <data key="d0">International Normalized Ratio</data>
      <data key="d1">data</data>
      <data key="d2">The International Normalized Ratio (INR) is a measurement used for managing warfarin, requiring a target range of 2 to 3.5 for post-MI patients.</data>
      <data key="d3">chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190211</data>
      <data key="d6" />
    </node>
    <node id="Glucose Control">
      <data key="d0">Glucose Control</data>
      <data key="d1">concept</data>
      <data key="d2">Glucose control is one of the components of medical treatment for chronic ischaemic heart disease.</data>
      <data key="d3">chunk-725fd25b2b914218473f4027eb936a0b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190211</data>
      <data key="d6" />
    </node>
    <node id="Lipid Profile">
      <data key="d0">Lipid Profile</data>
      <data key="d1">concept</data>
      <data key="d2">Lipid profile management is recommended as part of medical treatment for chronic ischaemic heart disease.</data>
