    </node>
    <node id="Physical Inactivity">
      <data key="d0">Physical Inactivity</data>
      <data key="d1">concept</data>
      <data key="d2">Physical inactivity is a life-habit risk factor that contributes to CHD risk.</data>
      <data key="d3">chunk-6bd98e2ff824d23b7b1224dc2e08b50a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776184711</data>
