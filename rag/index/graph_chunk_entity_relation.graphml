    <edge source="Beta-Blockers" target="Heart Failure">
      <data key="d7">1.0</data>
      <data key="d8">Beta-blockers have been shown to reduce total mortality in patients with compensated heart failure.</data>
      <data key="d9">Mortality Reduction,Treatment</data>
      <data key="d10">chunk-0a8a07023292447dd472b098aca92a15</data>
