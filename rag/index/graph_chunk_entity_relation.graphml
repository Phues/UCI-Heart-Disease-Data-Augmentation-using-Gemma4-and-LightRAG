    <node id="Adult Treatment Panel III">
      <data key="d0">Adult Treatment Panel III</data>
      <data key="d1">content</data>
      <data key="d2">Adult Treatment Panel III is the name given to the third expert panel report by the National Cholesterol Education Program.&lt;SEP&gt;This panel is used in the clinical criteria defining the metabolic syndrome.</data>
      <data key="d3">chunk-6a0733bca7611147bd0d7b8452e9cd47&lt;SEP&gt;chunk-089153c0a9e43f431c755dfee9cbc20e</data>
