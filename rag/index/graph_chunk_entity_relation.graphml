      <data key="d0">Suspected Aortic Dissection</data>
      <data key="d1">concept</data>
      <data key="d2">A condition that is an absolute contraindication for initiating specific treatments due to high risk.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190068</data>
      <data key="d6" />
    </node>
