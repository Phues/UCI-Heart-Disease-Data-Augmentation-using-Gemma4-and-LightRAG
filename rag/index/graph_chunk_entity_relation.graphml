    <node id="Ruth Ann Jordan, M.D.">
      <data key="d0">Ruth Ann Jordan, M.D.</data>
      <data key="d1">person</data>
      <data key="d2">Ruth Ann Jordan is the representative from the American College of Occupational and Environmental Medicine.</data>
      <data key="d3">chunk-4417d5a880fb11a8f66ef7c4eb00233a</data>
