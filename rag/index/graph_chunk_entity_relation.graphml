    <node id="Urokinase">
      <data key="d0">Urokinase</data>
      <data key="d1">content</data>
      <data key="d2">A nonselected thrombolytic agent mentioned in the context of patient treatment.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190069</data>
      <data key="d6" />
    </node>
    <node id="Severe Hypertension">
      <data key="d0">Severe Hypertension</data>
      <data key="d1">concept</data>
      <data key="d2">High blood pressure (BP &gt; 180/110 mm.Hg.) that is a relative contraindication for treatment.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190069</data>
