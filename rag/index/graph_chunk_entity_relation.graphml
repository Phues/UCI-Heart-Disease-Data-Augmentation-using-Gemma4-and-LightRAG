    <edge source="Blood Pressure Control" target="Blood Pressure Readings">
      <data key="d7">1.0</data>
      <data key="d8">Blood pressure control requires individualized drug management to ensure readings are consistently at or below 140/90 mmHg.</data>
      <data key="d9">individualized care,therapeutic target</data>
