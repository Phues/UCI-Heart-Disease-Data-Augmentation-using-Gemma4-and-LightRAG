      <data key="d0">Primary Percutaneous Coronary Intervention (PCI)</data>
      <data key="d1">method</data>
      <data key="d2">PCI is a procedure that can serve as an alternative to thrombolysis under specific conditions.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190067</data>
