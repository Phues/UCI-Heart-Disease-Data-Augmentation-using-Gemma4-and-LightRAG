      <data key="d0">Haemorrhagic CVA</data>
      <data key="d1">concept</data>
      <data key="d2">History of any hemorrhagic cerebrovascular accident is listed as an absolute contraindication.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190068</data>
