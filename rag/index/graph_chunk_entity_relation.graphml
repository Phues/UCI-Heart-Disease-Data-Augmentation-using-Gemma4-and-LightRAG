      <data key="d0">Ministry Of Health And Quality Of Life/Mauritius Institute Of Health</data>
      <data key="d1">organization</data>
      <data key="d2">A governmental/health body listed in the context header regarding medical services and standards.&lt;SEP&gt;This organization is listed as a source for health information regarding coronary artery disease prevention.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96&lt;SEP&gt;chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190059</data>
      <data key="d6" />
    </node>
    <node id="Worsening Anginal Symptoms">
      <data key="d0">Worsening Anginal Symptoms</data>
      <data key="d1">concept</data>
      <data key="d2">Anginal symptoms that require referral to a cardiologist.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190059</data>
      <data key="d6" />
    </node>
    <node id="Acute Coronary Syndrome">
      <data key="d0">Acute Coronary Syndrome</data>
      <data key="d1">concept</data>
      <data key="d2">ACS is a group of conditions that share a common pathophysiology involving the rupture of a vulnerable plaque.&lt;SEP&gt;Acute Coronary Syndrome is the main medical condition discussed, requiring intensive monitoring and specific therapeutic interventions.&lt;SEP&gt;A medical condition that requires immediate referral to a cardiologist.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96&lt;SEP&gt;chunk-e6bcb6c446cca77c7de2fbf5c07b59b0&lt;SEP&gt;chunk-725fd25b2b914218473f4027eb936a0b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190059</data>
      <data key="d6" />
    </node>
    <node id="Cardiologist">
      <data key="d0">Cardiologist</data>
      <data key="d1">person</data>
      <data key="d2">A cardiologist is a specialist who evaluates patients, especially those with worsening symptoms, for advanced cardiac interventions.&lt;SEP&gt;A medical specialist to whom patients with certain symptoms or syndromes should be referred.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96&lt;SEP&gt;chunk-725fd25b2b914218473f4027eb936a0b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190059</data>
      <data key="d6" />
    </node>
    <node id="Haemodynamic Instability">
      <data key="d0">Haemodynamic Instability</data>
      <data key="d1">concept</data>
      <data key="d2">A finding during physical examination that healthcare providers should look for.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190060</data>
      <data key="d6" />
    </node>
    <node id="Pulmonary Congestion">
      <data key="d0">Pulmonary Congestion</data>
      <data key="d1">concept</data>
      <data key="d2">A finding during physical examination that healthcare providers should look for.&lt;SEP&gt;The accumulation of fluid in the lungs, which is a cause of dyspnea.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96&lt;SEP&gt;chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190060</data>
      <data key="d6" />
    </node>
    <node id="Ischaemic Mitral Regurgitation">
      <data key="d0">Ischaemic Mitral Regurgitation</data>
      <data key="d1">concept</data>
      <data key="d2">A cardiac condition suggesting papillary muscle dysfunction or rupture.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190060</data>
