      <data key="d0">Intracranial Neoplasm</data>
      <data key="d1">concept</data>
      <data key="d2">A known tumor in the brain that is an absolute contraindication for certain treatments.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190068</data>
