      <data key="d6" />
    </node>
    <node id="Alan J. Garber, M.D., Ph.D.">
      <data key="d0">Alan J. Garber, M.D., Ph.D.</data>
      <data key="d1">person</data>
      <data key="d2">Alan J. Garber is the representative from the American Diabetes Association, Inc.</data>
      <data key="d3">chunk-4417d5a880fb11a8f66ef7c4eb00233a</data>
      <data key="d4">unknown_source</data>
