      <data key="d0">Intracerebral Hemorrhage</data>
      <data key="d1">naturalobject</data>
      <data key="d2">A serious bleeding event in the brain that is a risk associated with fibrinolytic agents.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190068</data>
