    <node id="The Seventh Report Of The Joint National Committee On Prevention, Detection, Evaluation, And Treatment Of High Blood Pressure (JNC 7)">
      <data key="d0">The Seventh Report Of The Joint National Committee On Prevention, Detection, Evaluation, And Treatment Of High Blood Pressure (JNC 7)</data>
      <data key="d1">content</data>
      <data key="d2">The report provides evidence-based guidelines for the prevention and management of hypertension.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186371</data>
      <data key="d6" />
    </node>
    <node id="Joint National Committee On Prevention, Detection, Evaluation, And Treatment Of High Blood Pressure (JNC 7)">
      <data key="d0">Joint National Committee On Prevention, Detection, Evaluation, And Treatment Of High Blood Pressure (JNC 7)</data>
      <data key="d1">organization</data>
      <data key="d2">The body responsible for issuing the guidelines regarding the evaluation and treatment of high blood pressure.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186371</data>
      <data key="d6" />
    </node>
    <node id="National Heart, Lung, And Blood Institute (NHLBI)">
      <data key="d0">National Heart, Lung, And Blood Institute (NHLBI)</data>
      <data key="d1">organization</data>
      <data key="d2">NHLBI is the entity that administered the program and published the JNC 7 report materials.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186371</data>
      <data key="d6" />
    </node>
    <node id="National High Blood Pressure Education Program (NHBPEP) Coordinating Committee">
      <data key="d0">National High Blood Pressure Education Program (NHBPEP) Coordinating Committee</data>
      <data key="d1">organization</data>
      <data key="d2">The committee was involved in the production of the JNC 7 report and coordinating related efforts.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186371</data>
      <data key="d6" />
    </node>
    <node id="JNC 7 Guidelines">
      <data key="d0">JNC 7 Guidelines</data>
      <data key="d1">content</data>
      <data key="d2">The JNC 7 guidelines offer evidence-based recommendations to clinicians and the public regarding blood pressure management.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186371</data>
      <data key="d6" />
    </node>
    <node id="Goal Blood Pressure">
      <data key="d0">Goal Blood Pressure</data>
      <data key="d1">data</data>
      <data key="d2">The optimal blood pressure goals are defined as &lt;140/90 mmHg or &lt;130/80 mmHg for diabetics.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186372</data>
      <data key="d6" />
    </node>
    <node id="Systolic Blood Pressure (SBP)">
      <data key="d0">Systolic Blood Pressure (SBP)</data>
      <data key="d1">concept</data>
      <data key="d2">SBP measures the pressure in the arteries when the heart beats, and the guidelines set goals for maintaining this measure.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186374</data>
      <data key="d6" />
    </node>
    <node id="Diastolic Blood Pressure (DBP)">
      <data key="d0">Diastolic Blood Pressure (DBP)</data>
      <data key="d1">concept</data>
      <data key="d2">DBP measures the pressure in the arteries when the heart is at rest, and the guidelines set goals for maintaining this measure.</data>
      <data key="d3">chunk-a158d7acb0688d684776ba9a5ab0bfa4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776186374</data>
      <data key="d6" />
    </node>
    <node id="Primary Care Clinicians">
      <data key="d0">Primary Care Clinicians</data>
      <data key="d1">person</data>
      <data key="d2">Primary Care Clinicians are professionals who are the intended audience for the JNC 7 report and guidelines.</data>
