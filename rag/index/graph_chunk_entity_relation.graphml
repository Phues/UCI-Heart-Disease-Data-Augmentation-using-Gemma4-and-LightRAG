    </node>
    <node id="National Heart Institute">
      <data key="d0">National Heart Institute</data>
      <data key="d1">organization</data>
      <data key="d2">The National Heart Institute is the organization where Jerome Cornfield was affiliated for the study.</data>
      <data key="d3">chunk-2a698820f9767612065e4d08199917ba</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188625</data>
      <data key="d6" />
    </node>
    <node id="Bethesda, Maryland">
      <data key="d0">Bethesda, Maryland</data>
      <data key="d1">location</data>
      <data key="d2">Bethesda, Maryland is the location where the National Heart Institute is situated.</data>
      <data key="d3">chunk-2a698820f9767612065e4d08199917ba</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188625</data>
