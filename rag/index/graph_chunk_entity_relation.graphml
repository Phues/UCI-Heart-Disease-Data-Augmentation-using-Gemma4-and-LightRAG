      <data key="d4">unknown_source</data>
      <data key="d5">1776190067</data>
      <data key="d6" />
    </node>
    <node id="Cardioversion">
      <data key="d0">Cardioversion</data>
      <data key="d1">method</data>
      <data key="d2">An electrical treatment used to manage Atrial Fibrillation and hemodynamic instability.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190068</data>
      <data key="d6" />
