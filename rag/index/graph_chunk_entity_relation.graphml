  <graph edgedefault="undirected">
    <node id="Cholesterol Level">
      <data key="d0">Cholesterol Level</data>
      <data key="d1">concept</data>
      <data key="d2">The serum cholesterol level, measured in mg, used in association studies concerning cardiac risk.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188616</data>
      <data key="d6" />
    </node>
    <node id="Blood Pressure">
      <data key="d0">Blood Pressure</data>
      <data key="d1">concept</data>
      <data key="d2">Blood pressure is a physiological measure that, when transformed by the logarithm (blood pressure – 75), can define a variable for statistical analysis.&lt;SEP&gt;Blood pressure is a variable measured in mm Hg that is correlated with risk.&lt;SEP&gt;The systolic blood pressure, measured in mm Hg, used in association studies concerning cardiac risk.&lt;SEP&gt;Blood Pressure is a critical measurement point for managing chronic ischaemic heart disease.&lt;SEP&gt;A physiological measurement that can be improved by exercise training and is a risk factor for CAD.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0&lt;SEP&gt;chunk-cc71e0306c5c259756e6206620a858b1&lt;SEP&gt;chunk-baa95425f9536fc6e61a6ea35b2d5490&lt;SEP&gt;chunk-5d706ae189b3bf78b45c9dc1e1b73ebf&lt;SEP&gt;chunk-725fd25b2b914218473f4027eb936a0b&lt;SEP&gt;chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190055</data>
      <data key="d6" />
    </node>
    <node id="Risk of Developing Coronary Heart Disease">
      <data key="d0">Risk of Developing Coronary Heart Disease</data>
      <data key="d1">concept</data>
      <data key="d2">The outcome variable whose increase is analyzed in relation to cholesterol and blood pressure levels.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188616</data>
      <data key="d6" />
    </node>
    <node id="Framingham Population">
      <data key="d0">Framingham Population</data>
      <data key="d1">organization</data>
      <data key="d2">The specific population used in the study to describe the relationships between risk, cholesterol, and blood pressure.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188616</data>
      <data key="d6" />
    </node>
    <node id="Discriminant Functions">
      <data key="d0">Discriminant Functions</data>
      <data key="d1">method</data>
      <data key="d2">Discriminant functions is a mathematical method that substitutes a formula to describe theoretical frequency distributions based on observed frequencies.&lt;SEP&gt;Mathematical functions used to describe the relationships among risk and the two variables (cholesterol and blood pressure).</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0&lt;SEP&gt;chunk-baa95425f9536fc6e61a6ea35b2d5490</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188616</data>
      <data key="d6" />
    </node>
    <node id="5th Percentile">
      <data key="d0">5th Percentile</data>
      <data key="d1">data</data>
      <data key="d2">The lower quartile threshold for either cholesterol or blood pressure, used for risk comparisons.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188616</data>
      <data key="d6" />
    </node>
    <node id="95th Percentile">
      <data key="d0">95th Percentile</data>
      <data key="d1">data</data>
      <data key="d2">The upper quartile threshold for either cholesterol or blood pressure, used for risk comparisons.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188616</data>
      <data key="d6" />
    </node>
    <node id="1% Difference">
      <data key="d0">1% Difference</data>
      <data key="d1">data</data>
      <data key="d2">A standardized unit of change used to quantify the difference in either cholesterol or blood pressure and its corresponding effect on risk.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188616</data>
      <data key="d6" />
    </node>
    <node id="2.66% Difference">
      <data key="d0">2.66% Difference</data>
      <data key="d1">data</data>
      <data key="d2">The percentage difference in risk associated with a 1% change in cholesterol, measured relative to a given blood pressure.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188618</data>
      <data key="d6" />
    </node>
    <node id="4.62% Difference">
      <data key="d0">4.62% Difference</data>
      <data key="d1">data</data>
      <data key="d2">The percentage difference in risk associated with a 1% change in systolic blood pressure, measured relative to a given cholesterol level.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188618</data>
      <data key="d6" />
    </node>
    <node id="110 mm Hg">
      <data key="d0">110 mm Hg</data>
      <data key="d1">data</data>
      <data key="d2">The starting systolic blood pressure value used as a reference point for assessing the 4.62% difference in risk.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188618</data>
      <data key="d6" />
    </node>
    <node id="175 mm Hg">
      <data key="d0">175 mm Hg</data>
      <data key="d1">data</data>
      <data key="d2">A specific systolic blood pressure value at which a 1% difference is associated with a 2.57% difference in risk.</data>
      <data key="d3">chunk-6d8cca0699acb22993f8cf6baa3a4bd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188618</data>
      <data key="d6" />
    </node>
    <node id="CHD Population">
      <data key="d0">CHD Population</data>
      <data key="d1">concept</data>
      <data key="d2">The CHD Population is the group whose risk of developing new cases is being studied, used for deriving risk coefficients.&lt;SEP&gt;The CHD population is one of the two populations studied, whose distributions (for cholesterol and blood pressure) are used to deduce the risk function.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1&lt;SEP&gt;chunk-baa95425f9536fc6e61a6ea35b2d5490</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188619</data>
      <data key="d6" />
    </node>
    <node id="NCHD Population">
      <data key="d0">NCHD Population</data>
      <data key="d1">concept</data>
      <data key="d2">The NCHD Population is a comparison group used in the calculation of risk coefficients, alongside the CHD Population.&lt;SEP&gt;The NCHD population is the second population studied, used in conjunction with the CHD population for statistical analysis.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1&lt;SEP&gt;chunk-baa95425f9536fc6e61a6ea35b2d5490</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188619</data>
      <data key="d6" />
    </node>
    <node id="Serum Cholesterol">
      <data key="d0">Serum Cholesterol</data>
      <data key="d1">naturalobject</data>
      <data key="d2">A physiological measurement variable used in calculating CHD risk, measured in mg/100 cc.&lt;SEP&gt;Serum cholesterol is a measurable value used to calculate the risk function, P(Y).&lt;SEP&gt;Serum cholesterol is a variable measured in the population to determine the associated risk of coronary heart disease.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1&lt;SEP&gt;chunk-baa95425f9536fc6e61a6ea35b2d5490&lt;SEP&gt;chunk-2a698820f9767612065e4d08199917ba</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188619</data>
      <data key="d6" />
    </node>
    <node id="Systolic Blood Pressure">
      <data key="d0">Systolic Blood Pressure</data>
      <data key="d1">naturalobject</data>
      <data key="d2">A physiological measurement variable used in calculating CHD risk, measured in mm Hg.&lt;SEP&gt;Systolic blood pressure is a variable measured in the population used to analyze the risk of coronary heart disease.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1&lt;SEP&gt;chunk-2a698820f9767612065e4d08199917ba</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188619</data>
      <data key="d6" />
    </node>
    <node id="Equation 5">
      <data key="d0">Equation 5</data>
      <data key="d1">artifact</data>
      <data key="d2">A mathematical formula (P = 1/[1 + exp{ -( + X + X ) } ]) used to model a probability (P).</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188620</data>
      <data key="d6" />
    </node>
    <node id="Equation 6">
      <data key="d0">Equation 6</data>
      <data key="d1">artifact</data>
      <data key="d2">A linear mathematical version of Equation 5 (log P/(1 - P) = + X + X) used to study quantitative risk dependence.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188620</data>
      <data key="d6" />
    </node>
    <node id="Discriminant Function">
      <data key="d0">Discriminant Function</data>
      <data key="d1">concept</data>
      <data key="d2">The right-hand side of Equation 6, whose numerical value can discriminate between individuals likely and unlikely to become members of the CHD population.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188620</data>
      <data key="d6" />
    </node>
    <node id="Table 2">
      <data key="d0">Table 2</data>
      <data key="d1">content</data>
      <data key="d2">A summary table detailing the New CHD in 6</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188620</data>
      <data key="d6" />
    </node>
    <node id="Variances">
      <data key="d0">Variances</data>
      <data key="d1">concept</data>
      <data key="d2">The Variances are statistical measures of variation used in the computation of coefficients related to risk modeling.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188620</data>
      <data key="d6" />
    </node>
    <node id="Correlation Coefficient">
      <data key="d0">Correlation Coefficient</data>
      <data key="d1">concept</data>
      <data key="d2">The Correlation Coefficient is a measure of the linear relationship between two variables, used in risk calculation models.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188620</data>
      <data key="d6" />
    </node>
    <node id="Confidence Limits">
      <data key="d0">Confidence Limits</data>
      <data key="d1">concept</data>
      <data key="d2">Formulas providing approximate limits for the coefficients used in the CHD risk model.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188621</data>
      <data key="d6" />
    </node>
    <node id="Log10 Cholesterol">
      <data key="d0">Log10 Cholesterol</data>
      <data key="d1">data</data>
      <data key="d2">A derived variable used in the model, representing the base-10 logarithm of cholesterol levels.&lt;SEP&gt;Log10 cholesterol is the base-10 logarithm of cholesterol, used as a key variable in the log normal and bivariate frequency distribution models.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1&lt;SEP&gt;chunk-baa95425f9536fc6e61a6ea35b2d5490</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188621</data>
      <data key="d6" />
    </node>
    <node id="Log (Blood Pressure - 75)">
      <data key="d0">Log (Blood Pressure - 75)</data>
      <data key="d1">data</data>
      <data key="d2">A derived variable used in the model, representing the base-10 logarithm of blood pressure minus 75.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188621</data>
      <data key="d6" />
    </node>
    <node id="Men 40-59">
      <data key="d0">Men 40-59</data>
      <data key="d1">naturalobject</data>
      <data key="d2">The demographic group that is the subject population for the tracking of New CHD cases presented in Table 2.</data>
      <data key="d3">chunk-5bb2a0ef3170a42757aa612ccebe04e1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776188621</data>
      <data key="d6" />
