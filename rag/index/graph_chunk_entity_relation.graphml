      <data key="d1">concept</data>
      <data key="d2">A cardiac condition requiring investigation and management with pacing.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190069</data>
      <data key="d6" />
    </node>
    <node id="Dyspnea">
      <data key="d0">Dyspnea</data>
      <data key="d1">concept</data>
      <data key="d2">The primary symptom of congestive heart failure, caused by pulmonary congestion and tachycardia.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190069</data>
      <data key="d6" />
    </node>
    <node id="Left Ventricular Function">
      <data key="d0">Left Ventricular Function</data>
      <data key="d1">concept</data>
      <data key="d2">The contractile performance of the left ventricle, which dictates the benefit of ACE inhibitors.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190069</data>
      <data key="d6" />
