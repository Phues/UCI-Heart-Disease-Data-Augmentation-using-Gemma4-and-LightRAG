    <edge source="Lipid Management" target="Statin Drug Therapy">
      <data key="d7">1.0</data>
      <data key="d8">Statin drug therapy is indicated for lipid management, potentially in combination if the LDL goal is not met.</data>
      <data key="d9">combination therapy,drug recommendation</data>
