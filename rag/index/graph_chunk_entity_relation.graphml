      <data key="d0">Procjaska</data>
      <data key="d1">person</data>
      <data key="d2">Procjaska is a theorist who, along with Diclemente, proposed the Stages of Change Model.</data>
      <data key="d3">chunk-4a07b3f1da8427b5b209e9546fe4fc9d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190145</data>
