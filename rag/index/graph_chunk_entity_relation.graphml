    <edge source="Lipid Management" target="LDL Cholesterol">
      <data key="d7">1.0</data>
      <data key="d8">LDL cholesterol levels are measured against specific goals (e.g., &lt; 100 mg/dl) to guide drug therapy decisions.</data>
      <data key="d9">quantifiable goal,treatment assessment</data>
      <data key="d10">chunk-fba062a869c808ddf245e61a4921a0b9</data>
