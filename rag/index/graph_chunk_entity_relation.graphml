    <node id="Ministry of Health And Quality Of Life/Mauritius Institute Of Health/World Health Organisation">
      <data key="d0">Ministry of Health And Quality Of Life/Mauritius Institute Of Health/World Health Organisation</data>
      <data key="d1">organization</data>
      <data key="d2">This organization is the source of the medical guidelines and clinical protocols regarding ACS management.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190070</data>
      <data key="d6" />
    </node>
    <node id="Oesophageal Pain">
      <data key="d0">Oesophageal Pain</data>
      <data key="d1">concept</data>
      <data key="d2">Oesophageal Pain is a symptom suspected in patients requiring potential treatment with an oral antacid.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190070</data>
      <data key="d6" />
    </node>
    <node id="Gastric Pain">
      <data key="d0">Gastric Pain</data>
      <data key="d1">concept</data>
      <data key="d2">Gastric Pain is a symptom suspected in patients requiring potential treatment with an oral antacid.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190070</data>
      <data key="d6" />
    </node>
    <node id="Oral Antacid">
      <data key="d0">Oral Antacid</data>
      <data key="d1">content</data>
      <data key="d2">An oral antacid is a treatment that can be administered if oesophageal or gastric pain is suspected.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190070</data>
      <data key="d6" />
    </node>
    <node id="Tachycardia">
      <data key="d0">Tachycardia</data>
      <data key="d1">concept</data>
      <data key="d2">Tachycardia is a condition involving an elevated heart rate, suggesting a high-risk status requiring beta-blockers.&lt;SEP&gt;Tachycardia is a physiological sign that may be present during acute coronary syndromes.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0&lt;SEP&gt;chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190070</data>
      <data key="d6" />
    </node>
    <node id="Persistent Chest Pain">
      <data key="d0">Persistent Chest Pain</data>
      <data key="d1">concept</data>
      <data key="d2">Persistent Chest Pain is a recurring symptom used as a high-risk feature that indicates the need for further therapy.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190070</data>
      <data key="d6" />
    </node>
    <node id="Ischaemic Ecg Changes">
      <data key="d0">Ischaemic Ecg Changes</data>
      <data key="d1">concept</data>
      <data key="d2">Ischaemic ECG changes are changes observed on the electrocardiogram, signifying underlying ischemia and indicating high risk.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190071</data>
      <data key="d6" />
    </node>
    <node id="Intravenous Beta-blockers">
      <data key="d0">Intravenous Beta-blockers</data>
      <data key="d1">content</data>
      <data key="d2">Intravenous beta-blockers are medications administered when multiple high-risk symptoms are present, such as severe hypertension or tachycardia.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190071</data>
      <data key="d6" />
    </node>
    <node id="Oral Beta-blockade">
      <data key="d0">Oral Beta-blockade</data>
      <data key="d1">content</data>
      <data key="d2">Oral beta-blockade, exemplified by atenolol, is a prophylactic treatment recommended for all patients without contraindications.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190131</data>
      <data key="d6" />
    </node>
    <node id="Atenolol">
      <data key="d0">Atenolol</data>
      <data key="d1">content</data>
      <data key="d2">Atenolol is a specific beta-blocker dosage (25–50 mg once daily) used for oral blockade in stable patients.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190131</data>
      <data key="d6" />
    </node>
    <node id="Antithrombotic Therapy">
      <data key="d0">Antithrombotic Therapy</data>
      <data key="d1">concept</data>
      <data key="d2">Antithrombotic therapy is a group of treatments indicated for high-risk ACS patients, preventing blood clots.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190132</data>
      <data key="d6" />
    </node>
    <node id="Anticoagulant Therapy">
      <data key="d0">Anticoagulant Therapy</data>
      <data key="d1">concept</data>
      <data key="d2">Anticoagulant therapy is a group of treatments indicated for high-risk ACS patients, preventing blood clots.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190132</data>
      <data key="d6" />
    </node>
    <node id="Unfractionated Heparin">
      <data key="d0">Unfractionated Heparin</data>
      <data key="d1">content</data>
      <data key="d2">Unfractionated heparin is a mainstay anticoagulant used in the treatment of ACS, often compared against newer agents.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190132</data>
      <data key="d6" />
    </node>
    <node id="Low Molecular Weight Heparins">
      <data key="d0">Low Molecular Weight Heparins</data>
      <data key="d1">content</data>
      <data key="d2">Low molecular weight heparins are a newer class of anticoagulants that demonstrate reduced risk compared to unfractionated heparin.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190132</data>
      <data key="d6" />
    </node>
    <node id="Enoxaparin (Lovenox)">
      <data key="d0">Enoxaparin (Lovenox)</data>
      <data key="d1">content</data>
      <data key="d2">Enoxaparin, marketed as Lovenox, is a specific low molecular weight heparin shown to reduce combined endpoints</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190132</data>
      <data key="d6" />
    </node>
    <node id="Glycoprotein IIb/IIIa Receptor">
      <data key="d0">Glycoprotein IIb/IIIa Receptor</data>
      <data key="d1">concept</data>
      <data key="d2">The receptor represents the final common pathway for platelet aggregation via fibrin binding and cross-linking.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190132</data>
      <data key="d6" />
    </node>
    <node id="Antibody Fragment (abciximab)">
      <data key="d0">Antibody Fragment (abciximab)</data>
      <data key="d1">content</data>
      <data key="d2">Antibody fragment abciximab is an antagonist developed to inhibit platelet aggregation via the GP IIb/IIIa receptor.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190133</data>
      <data key="d6" />
    </node>
    <node id="Peptide (Eptifibatide, Tirofiban)">
      <data key="d0">Peptide (Eptifibatide, Tirofiban)</data>
      <data key="d1">content</data>
      <data key="d2">Peptide antagonists, specifically eptifibatide and tirofiban, are used to inhibit platelet aggregation at the GP IIb/IIIa receptor.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190133</data>
      <data key="d6" />
    </node>
    <node id="Cardiac Catheterization">
      <data key="d0">Cardiac Catheterization</data>
      <data key="d1">method</data>
      <data key="d2">Cardiac catheterization is a procedure typically indicated if chest pain persists or recurs, alongside objective evidence of ischemia.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190133</data>
      <data key="d6" />
    </node>
    <node id="Revascularization">
      <data key="d0">Revascularization</data>
      <data key="d1">method</data>
      <data key="d2">Revascularization is a procedure that should be considered if suitable coronary anatomy is present, potentially following cardiac catheterization.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190133</data>
      <data key="d6" />
    </node>
    <node id="Smoking">
      <data key="d0">Smoking</data>
      <data key="d1">concept</data>
      <data key="d2">Smoking is listed as a cardiac risk factor that must be controlled during secondary prevention of ACS.&lt;SEP&gt;Smoking is a health hazard responsible for a significant portion of all avoidable deaths, particularly cardiovascular death.&lt;SEP&gt;Smoking is identified as a risk factor for CVD, necessitating complete cessation.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0&lt;SEP&gt;chunk-1402c215c7fd318145880a62d19e2b3a&lt;SEP&gt;chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190133</data>
      <data key="d6" />
    </node>
    <node id="Diabetes">
      <data key="d0">Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetes is identified as a cardiac risk factor that requires control during secondary prevention of ACS.&lt;SEP&gt;Diabetes requires appropriate Oral Hypoglycemic Agent (OHA) use to achieve near normal Fasting Plasma Glucose (FPG).</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0&lt;SEP&gt;chunk-fba062a869c808ddf245e61a4921a0b9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190133</data>
      <data key="d6" />
    </node>
    <node id="Prothrombin Time">
      <data key="d0">Prothrombin Time</data>
      <data key="d1">data</data>
      <data key="d2">Prothrombin time is a target monitoring value during advanced ACS therapy, aiming for 1.5 to 2 times the control range.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190134</data>
      <data key="d6" />
    </node>
    <node id="N-3-omega Fatty Acids">
      <data key="d0">N-3-omega Fatty Acids</data>
      <data key="d1">content</data>
      <data key="d2">N-3-omega fatty acids are a type of fat, along with monounsaturated fats and antioxidants, found in cardioprotective diets.</data>
      <data key="d3">chunk-e6bcb6c446cca77c7de2fbf5c07b59b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190134</data>
      <data key="d6" />
    </node>
    <node id="Mediterranean Diet">
      <data key="d0">Mediterranean Diet</data>
      <data key="d1">concept</data>
      <data key="d2">The Mediterranean diet is characterized by being low in saturated fat and high in unsaturated fat, and is associated with good life expectancy.&lt;SEP&gt;The Mediterranean Diet is associated with the best life expectancy, characterized by low saturated fat and high unsaturated fat, especially monounsaturated fat.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a&lt;SEP&gt;chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190134</data>
      <data key="d6" />
    </node>
    <node id="Japanese Diet">
      <data key="d0">Japanese Diet</data>
      <data key="d1">concept</data>
      <data key="d2">The Japanese diet is characterized by being low in saturated fat and high in complex carbohydrates, and is associated with good life expectancy.&lt;SEP&gt;The Japanese Diet is associated with the best life expectancy, characterized by low saturated fat and high complex carbohydrates.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a&lt;SEP&gt;chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190134</data>
      <data key="d6" />
    </node>
    <node id="Saturated Fatty Acids">
      <data key="d0">Saturated Fatty Acids</data>
      <data key="d1">content</data>
      <data key="d2">Saturated fatty acids are a dietary component that should be kept low in diets associated with best life expectancy.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190134</data>
      <data key="d6" />
    </node>
    <node id="Unsaturated Fatty Acids">
      <data key="d0">Unsaturated Fatty Acids</data>
      <data key="d1">content</data>
      <data key="d2">Unsaturated fatty acids are a beneficial dietary component, particularly monounsaturated types, associated with good life expectancy.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190135</data>
      <data key="d6" />
    </node>
    <node id="Complex Carbohydrates">
      <data key="d0">Complex Carbohydrates</data>
      <data key="d1">content</data>
      <data key="d2">Complex carbohydrates are a beneficial dietary component, key to the Japanese diet, and associated with good life expectancy.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190135</data>
      <data key="d6" />
    </node>
    <node id="Body Mass Index">
      <data key="d0">Body Mass Index</data>
      <data key="d1">method</data>
      <data key="d2">Body mass index is a measure of obesity calculated using weight in kilograms divided by the square of height in meters, and is recommended by the WHO expert committee.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190135</data>
      <data key="d6" />
    </node>
    <node id="Waist Hip Ratio">
      <data key="d0">Waist Hip Ratio</data>
      <data key="d1">method</data>
      <data key="d2">The waist hip ratio is an index used in epidemiology to assess central obesity, defined as fat accumulation to the trunk and abdominal cavity.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190135</data>
      <data key="d6" />
    </node>
    <node id="Waist Circumference">
      <data key="d0">Waist Circumference</data>
      <data key="d1">method</data>
      <data key="d2">Waist circumference is a recommended measurement for clinical assessment and follow-up during weight reduction for determining the degree of obesity.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190135</data>
      <data key="d6" />
    </node>
    <node id="Central Obesity">
      <data key="d0">Central Obesity</data>
      <data key="d1">concept</data>
      <data key="d2">Central obesity is the accumulation of fat to the trunk and abdominal cavity and is associated with high prevalence of lipid abnormalities and hypertension.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190136</data>
      <data key="d6" />
    </node>
    <node id="Type 1 Diabetes">
      <data key="d0">Type 1 Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Type 1 diabetes is a condition associated with a marked increase of CHD, with risk becoming evident after the age of 30.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190136</data>
      <data key="d6" />
    </node>
    <node id="Type 2 Diabetes">
      <data key="d0">Type 2 Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Type 2 diabetes is a condition associated with more profound abnormalities in cardiovascular risk factors compared to Type 1 diabetes.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190136</data>
      <data key="d6" />
    </node>
    <node id="Alcohol">
      <data key="d0">Alcohol</data>
      <data key="d1">content</data>
      <data key="d2">Alcohol is a substance whose consumption relationship with the risk of all cause mortality is described as J-shaped or U-shaped.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190136</data>
      <data key="d6" />
    </node>
    <node id="Monounsaturated Fat">
      <data key="d0">Monounsaturated Fat</data>
      <data key="d1">content</data>
      <data key="d2">Monounsaturated fat is a specific type of unsaturated fat considered beneficial, especially in the Mediterranean diet.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190136</data>
      <data key="d6" />
    </node>
    <node id="Dietician">
      <data key="d0">Dietician</data>
      <data key="d1">person</data>
      <data key="d2">A dietician is a professional source of assistance recommended for dietary interviews.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190137</data>
      <data key="d6" />
    </node>
    <node id="Trained Nurse">
      <data key="d0">Trained Nurse</data>
      <data key="d1">person</data>
      <data key="d2">A specially trained nurse is a professional source of assistance recommended for dietary interviews.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190137</data>
      <data key="d6" />
    </node>
    <node id="BMI Classification">
      <data key="d0">BMI Classification</data>
      <data key="d1">data</data>
      <data key="d2">A classification scheme for assessing obesity based on specific weight/height ranges (e.g., Normal weight, Grade 3 overweight).</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190137</data>
      <data key="d6" />
    </node>
    <node id="Impaired Glucose Tolerance">
      <data key="d0">Impaired Glucose Tolerance</data>
      <data key="d1">concept</data>
      <data key="d2">Impaired glucose tolerance is a health condition with recorded prevalence rates in adults aged 25 and above.&lt;SEP&gt;IGT is a condition associated with a cardiovascular risk pattern characteristic of type 2 diabetes.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a&lt;SEP&gt;chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190137</data>
      <data key="d6" />
    </node>
    <node id="Lipid Abnormalities">
      <data key="d0">Lipid Abnormalities</data>
      <data key="d1">concept</data>
      <data key="d2">Lipid abnormalities are high prevalence risks associated with central obesity.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190137</data>
      <data key="d6" />
    </node>
    <node id="Passive Smoking">
      <data key="d0">Passive Smoking</data>
      <data key="d1">concept</data>
      <data key="d2">Passive smoking is identified as a risk factor that increases the risk of cardiovascular disease.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190137</data>
      <data key="d6" />
    </node>
    <node id="Myocardial Necrosis">
      <data key="d0">Myocardial Necrosis</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Myocardial necrosis is a potential complication of rapid blood pressure reduction that reduces coronary autoregulation effectiveness.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190138</data>
      <data key="d6" />
    </node>
    <node id="Coronary Atherosclerosis">
      <data key="d0">Coronary Atherosclerosis</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Coronary atherosclerosis is a potential complication of rapid blood pressure reduction that reduces coronary autoregulation effectiveness.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190138</data>
      <data key="d6" />
    </node>
    <node id="Cardiac Hypertrophy">
      <data key="d0">Cardiac Hypertrophy</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Cardiac hypertrophy is a potential complication of rapid blood pressure reduction that reduces coronary autoregulation effectiveness.</data>
      <data key="d3">chunk-1402c215c7fd318145880a62d19e2b3a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190138</data>
      <data key="d6" />
    </node>
    <node id="Angioplasty">
      <data key="d0">Angioplasty</data>
      <data key="d1">method</data>
      <data key="d2">Angioplasty is a medical procedure mentioned in the context of coronary artery disease.</data>
      <data key="d3">chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190138</data>
      <data key="d6" />
    </node>
    <node id="Bypass Grafting">
      <data key="d0">Bypass Grafting</data>
      <data key="d1">method</data>
      <data key="d2">Bypass grafting is a medical procedure aimed at treating coronary artery disease.</data>
      <data key="d3">chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190139</data>
      <data key="d6" />
    </node>
    <node id="Risk Factor">
      <data key="d0">Risk Factor</data>
      <data key="d1">concept</data>
      <data key="d2">A risk factor describes characteristics found in healthy individuals that are independently related to the subsequent occurrence of coronary heart disease.</data>
      <data key="d3">chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190139</data>
      <data key="d6" />
    </node>
    <node id="Screening">
      <data key="d0">Screening</data>
      <data key="d1">method</data>
      <data key="d2">Screening for coronary artery disease is a technique that must be easy, precise, cost-effective, and acceptable to the community.</data>
      <data key="d3">chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190139</data>
      <data key="d6" />
    </node>
    <node id="Lifestyle Modification">
      <data key="d0">Lifestyle Modification</data>
      <data key="d1">concept</data>
      <data key="d2">Lifestyle modification can retard the development of coronary heart disease, both before and after a clinical event.</data>
      <data key="d3">chunk-8c2d4bf173facbfeaa65d8b86b3d62ca</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190139</data>
      <data key="d6" />
    </node>
    <node id="Non St Elevation Acute Coronary Syndrome">
      <data key="d0">Non St Elevation Acute Coronary Syndrome</data>
      <data key="d1">concept</data>
      <data key="d2">Non ST elevation acute coronary syndrome is defined by changes in a patient's angina status and includes presentations like new-onset angina and increasing severity of angina.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190139</data>
      <data key="d6" />
    </node>
    <node id="Non-St Elevation Myocardial Infarction">
      <data key="d0">Non-St Elevation Myocardial Infarction</data>
      <data key="d1">concept</data>
      <data key="d2">NSTEMI is a type of acute coronary syndrome defined by changes in a patient's angina status.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190139</data>
      <data key="d6" />
    </node>
    <node id="Physical Examination">
      <data key="d0">Physical Examination</data>
      <data key="d1">method</data>
      <data key="d2">Physical examination is useful for diagnosing non-ischaemic causes of pain, such as costochondritis and aortic dissection.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0&lt;SEP&gt;chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190140</data>
      <data key="d6" />
    </node>
    <node id="Complete Blood Count">
      <data key="d0">Complete Blood Count</data>
      <data key="d1">data</data>
      <data key="d2">CBC is a useful diagnostic test used to evaluate other causes of symptoms and concurrent medical conditions.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190140</data>
      <data key="d6" />
    </node>
    <node id="Electrolytes">
      <data key="d0">Electrolytes</data>
      <data key="d1">data</data>
      <data key="d2">Electrolytes are useful data measured during testing to evaluate concurrent medical conditions.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190140</data>
      <data key="d6" />
    </node>
    <node id="Renal Function Tests">
      <data key="d0">Renal Function Tests</data>
      <data key="d1">data</data>
      <data key="d2">Renal function tests are useful for diagnosing other causes of symptoms and evaluating for renal insufficiency.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190140</data>
      <data key="d6" />
    </node>
    <node id="Chest X-Ray">
      <data key="d0">Chest X-Ray</data>
      <data key="d1">data</data>
      <data key="d2">A chest x-ray is a useful test for diagnosing other causes of symptoms and evaluating for concurrent medical conditions.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190140</data>
      <data key="d6" />
    </node>
    <node id="Clotting Times">
      <data key="d0">Clotting Times</data>
      <data key="d1">data</data>
      <data key="d2">Clotting times should be obtained to exclude bleeding diatheses before antithrombotic therapy.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190140</data>
      <data key="d6" />
    </node>
    <node id="ECG Analysis">
      <data key="d0">ECG Analysis</data>
      <data key="d1">method</data>
      <data key="d2">ECG analysis is a cornerstone diagnostic testing method essential for risk stratification in acute coronary syndromes.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190141</data>
      <data key="d6" />
    </node>
    <node id="Serum Cardiac Markers">
      <data key="d0">Serum Cardiac Markers</data>
      <data key="d1">data</data>
      <data key="d2">Markers like CK-MB and troponin I or T are cornerstone diagnostic tests used to determine myocardial injury.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190141</data>
      <data key="d6" />
    </node>
    <node id="Non-Ischaemic Causes Of Pain">
      <data key="d0">Non-Ischaemic Causes Of Pain</data>
      <data key="d1">concept</data>
      <data key="d2">This concept includes conditions such as costochondritis, pneumonia, pericarditis, aortic dissection, and upper gastrointestinal disease, which can mimic ACS pain.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190141</data>
      <data key="d6" />
    </node>
    <node id="Nitroglycerin">
      <data key="d0">Nitroglycerin</data>
      <data key="d1">artifact</data>
      <data key="d2">Nitroglycerin (GTN, ISDN) is a drug used for pain relief and cardiac treatment, administered via intravenous or sublingual routes.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190141</data>
      <data key="d6" />
    </node>
    <node id="Beta Blockers">
      <data key="d0">Beta Blockers</data>
      <data key="d1">artifact</data>
      <data key="d2">Beta blockers are medications used for cardiac treatment and can be used unless contraindicated.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190141</data>
      <data key="d6" />
    </node>
    <node id="Low Molecular Weight Heparin">
      <data key="d0">Low Molecular Weight Heparin</data>
      <data key="d1">artifact</data>
      <data key="d2">Enoxaparin is a specific anticoagulant prescribed in the management of ACS, typically for 48 hours.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190141</data>
      <data key="d6" />
    </node>
    <node id="Ticlopidine">
      <data key="d0">Ticlopidine</data>
      <data key="d1">artifact</data>
      <data key="d2">Ticlopidine is an alternative medication for ACS if aspirin is contraindicated.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190142</data>
      <data key="d6" />
    </node>
    <node id="Glycoprotein 11b- 111a Receptor Inhibitors">
      <data key="d0">Glycoprotein 11b- 111a Receptor Inhibitors</data>
      <data key="d1">artifact</data>
      <data key="d2">Reopro or Integrelin are medications that act as inhibitors for the glycoprotein 11b- 111a receptor in ACS treatment.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190142</data>
      <data key="d6" />
    </node>
    <node id="Bradycardia">
      <data key="d0">Bradycardia</data>
      <data key="d1">concept</data>
      <data key="d2">Bradycardia is a physiological sign that may be present during acute coronary syndromes.</data>
      <data key="d3">chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
