    </node>
    <node id="Federation of American Societies for Experimental Biology">
      <data key="d0">Federation of American Societies for Experimental Biology</data>
      <data key="d1">organization</data>
      <data key="d2">The Federation of American Societies for Experimental Biology is the organization associated with the publication details of the study.</data>
      <data key="d3">chunk-2a698820f9767612065e4d08199917ba</data>
      <data key="d4">unknown_source</data>
