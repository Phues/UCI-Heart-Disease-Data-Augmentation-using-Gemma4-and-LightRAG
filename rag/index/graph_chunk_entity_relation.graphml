      <data key="d0">Acute MI</data>
      <data key="d1">concept</data>
      <data key="d2">Acute Myocardial Infarction, the diagnosis of which is characterized by changes in ECG waves.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190060</data>
      <data key="d6" />
    </node>
    <node id="Electrocardiogram">
      <data key="d0">Electrocardiogram</data>
      <data key="d1">artifact</data>
      <data key="d2">The medical tracing that serves as the hallmark diagnosis for Acute MI due to characteristic wave changes.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190060</data>
      <data key="d6" />
    </node>
    <node id="ST-T-Q Wave Changes">
      <data key="d0">ST-T-Q Wave Changes</data>
      <data key="d1">concept</data>
      <data key="d2">Changes (elevation, depression, inversion) detectable on the ECG across different phases of Acute MI.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190060</data>
      <data key="d6" />
    </node>
    <node id="Left Bundle Branch Block">
      <data key="d0">Left Bundle Branch Block</data>
      <data key="d1">concept</data>
      <data key="d2">A diagnostic sign on ECG, often indicating a large anterior wall infarction.&lt;SEP&gt;A form of heart block observed on an ECG that requires medical consideration.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96&lt;SEP&gt;chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190061</data>
      <data key="d6" />
    </node>
    <node id="Reperfusion Therapy">
      <data key="d0">Reperfusion Therapy</data>
      <data key="d1">method</data>
      <data key="d2">The primary treatment goal for patients with Acute MI, aiming to reduce irreversible myocardial damage.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190061</data>
      <data key="d6" />
    </node>
    <node id="Fibrinolytic Therapy">
      <data key="d0">Fibrinolytic Therapy</data>
      <data key="d1">method</data>
      <data key="d2">A type of therapy to be initiated early in the treatment of Acute MI.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190061</data>
      <data key="d6" />
    </node>
    <node id="Thrombolytic Therapy">
      <data key="d0">Thrombolytic Therapy</data>
      <data key="d1">method</data>
      <data key="d2">A type of therapy for Acute MI, subject to specific eligibility criteria.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190061</data>
      <data key="d6" />
    </node>
    <node id="Door-To-Needle Time">
      <data key="d0">Door-To-Needle Time</data>
      <data key="d1">data</data>
      <data key="d2">The critical timeframe of 20 to 30 minutes that should encompass initial evaluation for acute MI patients.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190061</data>
      <data key="d6" />
    </node>
    <node id="Cardiacogenic Shock">
      <data key="d0">Cardiacogenic Shock</data>
      <data key="d1">concept</data>
      <data key="d2">A serious clinical condition that a patient may present with after an acute MI.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190061</data>
      <data key="d6" />
    </node>
    <node id="Systolic Murmurs">
      <data key="d0">Systolic Murmurs</data>
      <data key="d1">data</data>
      <data key="d2">New murmurs found during physical examination, suggesting underlying cardiac issues.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190062</data>
      <data key="d6" />
    </node>
    <node id="Papillary Muscle Rupture">
      <data key="d0">Papillary Muscle Rupture</data>
      <data key="d1">concept</data>
      <data key="d2">A severe cause of mitral regurgitation.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190062</data>
      <data key="d6" />
    </node>
    <node id="Septum">
      <data key="d0">Septum</data>
      <data key="d1">naturalobject</data>
      <data key="d2">The anatomical area whose rupture or infarction can lead to cardiac defects.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190062</data>
      <data key="d6" />
    </node>
    <node id="ST-Segment Elevation">
      <data key="d0">ST-Segment Elevation</data>
      <data key="d1">data</data>
      <data key="d2">A specific ECG finding that can be highly indicative of acute infarction.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190062</data>
      <data key="d6" />
    </node>
    <node id="T-Wave Inversion">
      <data key="d0">T-Wave Inversion</data>
      <data key="d1">data</data>
      <data key="d2">A specific ECG finding that indicates the normal return of the ST segment over time.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190063</data>
      <data key="d6" />
    </node>
    <node id="QS Wave">
      <data key="d0">QS Wave</data>
      <data key="d1">data</data>
      <data key="d2">A specific ECG finding that may replace the R wave as a result of transmural necrosis.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190063</data>
      <data key="d6" />
    </node>
    <node id="12-Lead ECG Tracing">
      <data key="d0">12-Lead ECG Tracing</data>
      <data key="d1">artifact</data>
      <data key="d2">A comprehensive ECG recording used to determine the localization and extent of an infarction.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190063</data>
      <data key="d6" />
    </node>
    <node id="Papillary Muscle Dysfunction">
      <data key="d0">Papillary Muscle Dysfunction</data>
      <data key="d1">concept</data>
      <data key="d2">A medical issue suggesting dysfunction or rupture that can cause mitral regurgitation.</data>
      <data key="d3">chunk-41d9481df9dca8a996f49a342af0df96</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190063</data>
      <data key="d6" />
    </node>
    <node id="Myocardial Ischaemia">
      <data key="d0">Myocardial Ischaemia</data>
      <data key="d1">concept</data>
      <data key="d2">Myocardial ischaemia occurs when myocardial oxygen delivery cannot meet metabolic myocardial demands, resulting in subsequent angina.&lt;SEP&gt;Myocardial ischaemia results from a mismatch between coronary blood flow and myocardial oxygen demand.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4&lt;SEP&gt;chunk-725fd25b2b914218473f4027eb936a0b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190063</data>
      <data key="d6" />
    </node>
    <node id="Acute Coronary Syndromes">
      <data key="d0">Acute Coronary Syndromes</data>
      <data key="d1">condition</data>
      <data key="d2">A set of acute events sharing a common pathophysiology involving the rupture of plaque and subsequent thrombotic cascades.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190063</data>
      <data key="d6" />
    </node>
    <node id="Atherosclerotic Plaque">
      <data key="d0">Atherosclerotic Plaque</data>
      <data key="d1">artifact</data>
      <data key="d2">A lipid-rich intracoronary deposit that, upon rupture, initiates the chain of events leading to acute coronary syndromes.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190064</data>
      <data key="d6" />
    </node>
    <node id="Thrombus">
      <data key="d0">Thrombus</data>
      <data key="d1">concept</data>
      <data key="d2">A formed structure, usually occluding, that results from platelet aggregation and the inflammatory cascade following plaque rupture.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190064</data>
      <data key="d6" />
    </node>
    <node id="Myocardial Oxygen Delivery">
      <data key="d0">Myocardial Oxygen Delivery</data>
      <data key="d1">concept</data>
      <data key="d2">The supply of oxygen to the myocardium, primarily determined by the oxygen-carrying capacity of blood and coronary flow.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190064</data>
      <data key="d6" />
    </node>
    <node id="Exercise Stress Testing (EST)">
      <data key="d0">Exercise Stress Testing (EST)</data>
      <data key="d1">method</data>
      <data key="d2">Exercise Stress Testing (EST) is a sensitive and informative examination useful for the detection and quantification of chronic ischaemic heart disease&lt;SEP&gt;A sensitive examination used for the detection and quantification of chronic ischaemic heart disease in at-risk patients.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4&lt;SEP&gt;chunk-0a8a07023292447dd472b098aca92a15</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190064</data>
      <data key="d6" />
    </node>
    <node id="Cardiac Enzymes">
      <data key="d0">Cardiac Enzymes</data>
      <data key="d1">data</data>
      <data key="d2">Serial measurements of cardiac enzymes are used to demonstrate cell injury and diagnose non-ST elevation MI.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190064</data>
      <data key="d6" />
    </node>
    <node id="Infarcation">
      <data key="d0">Infarcation</data>
      <data key="d1">condition</data>
      <data key="d2">Transmural myocardial injury occurring if the vessel lumen is completely occluded or inadequate collateralisation is present.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190064</data>
      <data key="d6" />
    </node>
    <node id="Unstable Angina">
      <data key="d0">Unstable Angina</data>
      <data key="d1">condition</data>
      <data key="d2">A clinical condition diagnosed if ischaemia occurs without demonstrable cell injury, noted by negative serial enzyme measurements.&lt;SEP&gt;Unstable angina is one type of acute coronary syndrome included under the definition of Non ST elevation acute coronary syndrome.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4&lt;SEP&gt;chunk-ba47882bd330c094f4cf8a1a605cf0b0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190065</data>
      <data key="d6" />
    </node>
    <node id="Supply-Demand Mismatch">
      <data key="d0">Supply-Demand Mismatch</data>
      <data key="d1">concept</data>
      <data key="d2">This mismatch occurs when myocardial oxygen delivery cannot meet the metabolic myocardial demands, leading to ischaemia.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190065</data>
      <data key="d6" />
    </node>
    <node id="Coronary Flow Reserve">
      <data key="d0">Coronary Flow Reserve</data>
      <data key="d1">concept</data>
      <data key="d2">Coronary flow reserve is the capacity of coronary blood flow to increase three to fivefold in response to exercise.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190065</data>
      <data key="d6" />
    </node>
    <node id="Stenosis">
      <data key="d0">Stenosis</data>
      <data key="d1">concept</data>
      <data key="d2">Significant atherosclerotic plaquing in the epicardial coronary arteries, causing a drop in blood pressure across the affected lesion.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190065</data>
      <data key="d6" />
    </node>
    <node id="Inflammatory Cascade">
      <data key="d0">Inflammatory Cascade</data>
      <data key="d1">concept</data>
      <data key="d2">A sequence of biochemical and biological events, including cytokine release and platelet activation, initiated by plaque rupture.</data>
      <data key="d3">chunk-66cab5fae30b68ce441cbeaea72167d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190066</data>
      <data key="d6" />
    </node>
    <node id="Ministry Of Health And Quality Of Life/Mauritius Institute Of Health/World Health Organisation">
      <data key="d0">Ministry Of Health And Quality Of Life/Mauritius Institute Of Health/World Health Organisation</data>
      <data key="d1">organization</data>
      <data key="d2">This organization is listed as the source for the clinical guidelines provided.&lt;SEP&gt;This organization published the guidelines regarding ACS diagnosis and treatment.&lt;SEP&gt;The organization published medical guidelines regarding cardiac interventions and associated contraindications.&lt;SEP&gt;The organization published guidelines for Primary and Secondary Prevention programs for Non-Communicable Diseases (NCD) and Cardiovascular Disease.&lt;SEP&gt;This organization is the source of specific articles related to health topics.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d&lt;SEP&gt;chunk-ba47882bd330c094f4cf8a1a605cf0b0&lt;SEP&gt;chunk-4a07b3f1da8427b5b209e9546fe4fc9d&lt;SEP&gt;chunk-fba062a869c808ddf245e61a4921a0b9&lt;SEP&gt;chunk-725fd25b2b914218473f4027eb936a0b</data>
