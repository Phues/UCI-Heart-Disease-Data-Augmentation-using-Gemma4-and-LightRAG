    <node id="Acute Myocardial Infarction">
      <data key="d0">Acute Myocardial Infarction</data>
      <data key="d1">concept</data>
      <data key="d2">AMI is a cardiac event that can be indicated by ST segment elevation and requires various interventions.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190066</data>
      <data key="d6" />
    </node>
    <node id="ST Segment Elevation">
      <data key="d0">ST Segment Elevation</data>
      <data key="d1">concept</data>
      <data key="d2">Elevation of the ST segment exceeding 1.0 mV in two continuous ECG leads is indicative of AMI.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190066</data>
      <data key="d6" />
    </node>
    <node id="Cardiogenic Shock">
      <data key="d0">Cardiogenic Shock</data>
      <data key="d1">concept</data>
      <data key="d2">A severe condition requiring specific immediate treatment protocols.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190066</data>
      <data key="d6" />
    </node>
    <node id="Atrial Fibrillation">
      <data key="d0">Atrial Fibrillation</data>
      <data key="d1">concept</data>
      <data key="d2">An irregular heart rhythm requiring specialized treatment, such as cardioversion.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190067</data>
      <data key="d6" />
    </node>
    <node id="Thrombolysis">
      <data key="d0">Thrombolysis</data>
      <data key="d1">concept</data>
      <data key="d2">A treatment process used for cardiac events, which carries risks of hemorrhage.</data>
      <data key="d3">chunk-3bade9898b872aa7e3336771b6b88e1d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776190067</data>
